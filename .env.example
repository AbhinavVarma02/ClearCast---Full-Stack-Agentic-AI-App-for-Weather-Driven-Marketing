# ClearCast Environment Variables
# Copy this file to .env and fill in your actual keys

# OpenWeatherMap API (free tier: https://openweathermap.org/api)
OPENWEATHERMAP_API_KEY=your_openweathermap_key_here

# OpenAI API (for GPT-4o-mini)
OPENAI_API_KEY=your_openai_key_here

# LangSmith (optional, for tracing: https://smith.langchain.com)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=clearcast
